#!/bin/bash

set -e
SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)
DOT_FOLDERS="bin,logseq,git,ghostty,tmux,yabai,zsh"

echo "[+] Dotfiles :: $SCRIPT_DIR"

if ! command -v stow &>/dev/null; then
	echo "Stow not installed"
	exit 1
fi

for folder in $(echo $DOT_FOLDERS | sed "s/,/ /g"); do
	echo "[+] Folder :: $folder"

	stow -t $HOME -D $folder \
		--ignore=README.md --ignore=LICENSE
	stow -t $HOME $folder
done

echo "[+] Linking Editor Settings (VS Code & Antigravity)"
mkdir -p "$HOME/Library/Application Support/Code/User"
mkdir -p "$HOME/Library/Application Support/Antigravity IDE/User"

# Remove existing files if they are not already symlinks (so ln -s can succeed)
rm -f "$HOME/Library/Application Support/Code/User/settings.json"
rm -f "$HOME/Library/Application Support/Code/User/keybindings.json"
rm -f "$HOME/Library/Application Support/Antigravity IDE/User/settings.json"
rm -f "$HOME/Library/Application Support/Antigravity IDE/User/keybindings.json"

ln -sf "$SCRIPT_DIR/editor-settings/settings.json" "$HOME/Library/Application Support/Code/User/settings.json"
ln -sf "$SCRIPT_DIR/editor-settings/keybindings.json" "$HOME/Library/Application Support/Code/User/keybindings.json"
ln -sf "$SCRIPT_DIR/editor-settings/settings.json" "$HOME/Library/Application Support/Antigravity IDE/User/settings.json"
ln -sf "$SCRIPT_DIR/editor-settings/keybindings.json" "$HOME/Library/Application Support/Antigravity IDE/User/keybindings.json"
